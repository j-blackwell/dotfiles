// This file has been consolidated and simplified from ML4W into the Hyprland configuration directory.
{
  "hyprland/workspaces": {
    "on-scroll-up": "hyprctl dispatch workspace r-1",
    "on-scroll-down": "hyprctl dispatch workspace r+1",
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "format": "{}",
    "persistent-workspaces": {
      "*": 1
    }
  },

  "hyprland/window": {
    "max-length": 60,
    "rewrite": {
      "(.*) - Brave": "$1",
      "(.*) - Chromium": "$1",
      "(.*) - Brave Search": "$1",
      "(.*) - Outlook": "$1",
      "(.*) Microsoft Teams": "$1"
    },
    "separate-outputs": true
  },

  "custom/idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "яБо",
      "deactivated": "яБ░"
    },
    "timeout": 30.5
  },

  "custom/updates": {
    "format": "яЖ▓  {}",
    "escape": true,
    "return-type": "json",
    "exec": "~/.config/hypr/scripts/updates.sh",
    "interval": 1800,
    "signal": 1,
    "hide-empty-text": true,
    "on-click": "~/.config/hypr/settings/installupdates.sh",
    "on-click-right": "~/.config/hypr/settings/software.sh"
  },


  "custom/exit": {
    "format": "яАС",
    "on-click": "~/.config/hypr/scripts/wlogout.sh",
    "on-click-right": "hyprlock",
    "tooltip-format": "Left: Power menu\nRight: Lock screen"
  },

  "custom/notification": {
    "tooltip-format": "Left: Notifications\nRight: Do not disturb",
    "format": "{icon}",
    "format-icons": {
      "notification": "<span rise='8pt'>яВв<span foreground='red'><sup>яСД</sup></span></span>",
      "none": "яВв",
      "dnd-notification": "<span rise='8pt'>яВв<span foreground='red'><sup>яСД</sup></span></span>",
      "dnd-none": "яЗ╖",
      "inhibited-notification": "<span rise='8pt'>яВв<span foreground='red'><sup>яСД</sup></span></span>",
      "inhibited-none": "яВв",
      "dnd-inhibited-notification": "<span rise='8pt'>яЗ╖<span foreground='red'><sup>яСД</sup></span></span>",
      "dnd-inhibited-none": "яЗ╖"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },

  "tray": {
    "icon-size": 21,
    "spacing": 10
  },

  "clock": {
    "format": "{:%Y-%m-%d %H:%M:%S}",
    "tooltip-format": "{:%A\n%Y-%m-%d}",
    "on-click": "flatpak run com.ml4w.calendar",
    "timezone": "",
    "tooltip": true,
    "interval": 1
  },

  "cpu": {
    "format": "ґ░╗а {usage}%",
    "on-click": "~/.config/hypr/settings/system-monitor.sh",
    "min-length": 5
  },

  "memory": {
    "format": "ю┐Е  {}%",
    "on-click": "~/.config/hypr/settings/system-monitor.sh",
    "min-length": 5
  },

  "hyprland/language": {
    "format": "яДЬ  {short}"
  },

  "network": {
    "format": "{ifname}",
    "interval": 5,
    "format-wifi": "яЗл  тЖУ{bandwidthDownBits}",
    "format-ethernet": "яЮЦ   тЖУ{bandwidthDownBits}",
    "format-disconnected": "Disconnected тЪа",
    "tooltip-format": "яЮЦ {ifname} via {gwaddri}",
    "tooltip-format-wifi": "яЗл  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nUp: {bandwidthUpBits}\nDown: {bandwidthDownBits}",
    "tooltip-format-ethernet": "яЮЦ {ifname}\nIP: {ipaddr}\n up: {bandwidthUpBits} down: {bandwidthDownBits}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "~/.config/hypr/settings/networkmanager.sh",
    "on-click-right": "~/.config/hypr/scripts/nm-applet.sh toggle",
    "min-length": 12
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "яЧз  {capacity}%",
    "format-plugged": "яЗж  {capacity}%",
    "format-alt": "{icon}  {time}",
    "format-icons": ["яЙД ", "яЙГ ", "яЙВ ", "яЙБ ", "яЙА "]
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "яКУ {volume}% {icon} {format_source}",
    "format-bluetooth-muted": "яКУ яЪй {format_source}",
    "format-muted": "яЪй {format_source}",
    "format-source": "{volume}% яД░",
    "format-source-muted": "яД▒",
    "format-icons": {
      "headphone": "яАе ",
      "hands-free": "яЦР ",
      "headset": "яЦР ",
      "phone": "яВХ ",
      "portable": "яВХ ",
      "car": "яЖ╣ ",
      "default": ["яАж", "яАи", "яАи"]
    },
    "on-click": "pavucontrol"
  },

  "bluetooth": {
    "format": "яКУ",
    "format-connected": "яКУ яАМ",
    "format-disconnected": "яКУ яАН",
    "format-disabled": "яКУ",
    "format-off": "яКУ",
    "format-no-controller": "",
    "interval": 30,
    "on-click": "blueman-manager",
    "tooltip": true,
    "tooltip-format": "{device_alias}",
    "min-length": 3
  }
}
