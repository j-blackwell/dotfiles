// ----------------------------------------------------- 
// Mocha-Power theme based on Jan-Aarela's dotfiles
// Adapted for hypr_simplified (based on ml4w-modern)
// ----------------------------------------------------- 

[
    {
        // MAIN BAR //
        "layer": "top",
        "position": "top",
        "name": "main",
        "height": 28,
        "reload_style_on_change": true,

        "margin-top": 24,
        "margin-left": 24,
        "margin-right": 24,
        "spacing": 0,

        // Load Modules
        "include": [
            "~/.config/waybar/modules.json"
        ],

        "modules-left": [
            "group/traym",
            "hyprland/workspaces",
            "hyprland/submap",
            "hyprland/window"
        ],

        "modules-right": [
            "custom/spacer1",
            "custom/updates",
            "custom/spacer-bg1",
            "temperature",
            "custom/spacer-bg1",
            "custom/sysusage",
            "custom/spacer-bg1",
            "custom/bandwidth",
            "custom/spacer2",
            "pulseaudio",
            "custom/spacer3",
            "bluetooth",
            "custom/spacer-bg1",
            "hyprland/language",
            "custom/spacer-bg1",
            "backlight",
            "custom/spacer-bg1",
            "battery",
            "custom/spacer4",
            "custom/weather",
            "custom/spacer-bg2",
            "custom/calendar",
            "custom/spacer-bg2",
            "clock"
        ],

        "group/traym": {
            "orientation": "horizontal",
            "drawer": {},
            "modules": ["custom/trayicon", "tray"]
        },

        "backlight": {
            "device": "intel_backlight",
            "format": "{icon} {percent}%",
            "format-icons": ["󱩎", "󱩑", "󱩓", "󱩕", "󰛨"],
            "scroll-step": 1,
            "on-scroll-up": "brightnessctl set 2%-",
            "on-scroll-down": "brightnessctl set +2%"
        },

        "hyprland/submap": {
            "always-on": true,
            "default-submap": "",
            "format": "{}",
            "format-RESIZE": "{}lol",
            "tooltip": false
        },

        "custom/spacer1": {
            "format": "",
            "tooltip": false
        },

        "custom/spacer2": {
            "format": "",
            "tooltip": false
        },

        "custom/spacer3": {
            "format": "",
            "tooltip": false
        },

        "custom/spacer4": {
            "format": "",
            "tooltip": false
        },

        "custom/spacer-bg1": {
            "format": "",
            "tooltip": false
        },

        "custom/spacer-bg2": {
            "format": "",
            "tooltip": false
        },

        "custom/trayicon": {
            "format": "ᗧ ",
            "tooltip": false
        }
    },

    {
        // INDICATOR BAR //
        "layer": "top",
        "position": "top",
        "name": "indicator",
        "passthrough": true,
        "reload_style_on_change": true,

        "height": 30,

        "margin-top": -29,
        "margin-right": 24,

        "modules-right": ["custom/batteryindicator"],

        "custom/batteryindicator": {
            "interval": 4,
            "return-type": "json",
            "tooltip": false,
            "format": " ",
            "exec": "~/.config/hypr/themes/Mocha-Power/bat-pp.sh bar"
        }
    }
]
